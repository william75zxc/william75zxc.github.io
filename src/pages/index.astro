---
import Layout from '../layouts/Layout.astro';
import { cv } from '../data/cv';

const { name, title, researchInterests, email, location, education, profileImage, bio } = cv;
---

<Layout title="Home">
	<section class="hero container">
		<div class="hero-content">
			<h1 class="hero-title">{name}</h1>
			<p class="hero-subtitle">{title}</p>
			<p class="hero-bio">{bio}</p>
			<div class="hero-actions">
				<a href="mailto:{email}" class="btn btn-primary">Contact Me</a>
				<a href="/publications" class="btn btn-outline">View Publications</a>
			</div>
		</div>
    <div class="hero-image-wrapper">
      <img src={profileImage} alt={name} class="hero-image glass" />
    </div>
	</section>

	<section class="research container">
		<h2 class="section-title">Research Interests</h2>
		<div class="interest-grid">
			{researchInterests.map((interest) => (
				<div class="interest-card glass">
					<div class="dot"></div>
					<p>{interest}</p>
				</div>
			))}
		</div>
	</section>

	<section class="education container">
		<h2 class="section-title">Education</h2>
		<div class="edu-list">
			{education.map((edu) => (
				<div class="edu-item glass">
					<div class="edu-header">
						<h3>{edu.institution}</h3>
						<span class="period">{edu.period}</span>
					</div>
					<p class="degree">{edu.degree}</p>
					<p class="location">{edu.location}</p>
				</div>
			))}
		</div>
	</section>
</Layout>

<style>
	.hero {
		display: grid;
		grid-template-columns: 1.5fr 1fr;
		gap: 4rem;
		align-items: center;
		min-height: 70vh;
	}
	.hero-content {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}
	.hero-title {
		font-size: 4rem;
		line-height: 1.1;
		font-weight: 800;
	}
	.hero-subtitle {
		font-size: 1.5rem;
		color: var(--accent-sky);
		font-weight: 600;
	}
	.hero-bio {
		font-size: 1.1rem;
		color: var(--text-secondary);
		max-width: 600px;
	}
	.hero-actions {
		display: flex;
		gap: 1rem;
		margin-top: 1rem;
	}
	.btn-outline {
		border: 1px solid var(--border-color);
		color: var(--text-primary);
	}
  .hero-image-wrapper {
    display: flex;
    justify-content: center;
    align-items: center;
  }
  .hero-image {
    width: 320px;
    height: 320px;
    object-fit: cover;
    border-radius: 2rem;
    box-shadow: 0 20px 40px rgba(0,0,0,0.4);
    border: 4px solid var(--border-color);
  }

	.interest-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
		gap: 1.5rem;
	}
	.interest-card {
		padding: 1.5rem;
		display: flex;
		align-items: center;
		gap: 1rem;
		transition: transform 0.3s ease;
	}
	.interest-card:hover {
		transform: scale(1.02);
	}
	.dot {
		width: 12px;
		height: 12px;
		background: var(--accent-teal);
		border-radius: 50%;
		flex-shrink: 0;
	}

	.edu-list {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}
	.edu-item {
		padding: 2rem;
	}
	.edu-header {
		display: flex;
		justify-content: space-between;
		align-items: flex-start;
		margin-bottom: 0.5rem;
	}
	.edu-header h3 {
		font-size: 1.5rem;
		color: var(--text-primary);
	}
	.period {
		background: var(--accent-gradient);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		font-weight: 700;
	}
	.degree {
		font-size: 1.1rem;
		color: var(--accent-sky);
		font-weight: 500;
	}
	.location {
		color: var(--text-secondary);
		font-size: 0.9rem;
	}

	@media (max-width: 968px) {
		.hero {
			grid-template-columns: 1fr;
			gap: 2rem;
			text-align: center;
			min-height: auto;
		}
		.hero-content {
			align-items: center;
		}
		.hero-title {
			font-size: 3rem;
		}
		.hero-actions {
			justify-content: center;
		}
	}
</style>
