---
import Layout from '../layouts/Layout.astro';
import Sidebar from '../components/Sidebar.astro';
import HighlightCard from '../components/HighlightCard.astro';
import { cv } from '../data/cv';

const { highlights, bio, heroText, tagline } = cv;
---

<Layout title="Home">
	<div class="container page-layout">
		<Sidebar />
		
		<main class="main-content">
			<section class="bio-hero glass">
        <h2 class="tagline">{tagline}</h2>
				<div class="bio-content">
          <p class="bio-paragraph">
            Focused on translational medical AI, with the goal of developing technologies that can be seamlessly integrated into real clinical workflows. Current work spans medical image analysis, multimodal deep learning, and VLM-based clinical applications.
          </p>
          <p class="bio-paragraph">
            Particular emphasis is placed on standards-based clinical integration through DICOM, DICOMweb, and FHIR, enabling automated inference and structured reporting within existing hospital systems.
          </p>
        </div>
        <p class="hero-context">{heroText}</p>
				<div class="hero-actions">
					<a href="/experience" class="btn btn-primary">Research Portfolio</a>
					<a href="/projects" class="btn btn-outline">Clinical Systems</a>
				</div>
			</section>

			<section class="highlights-section mt-12">
				<div class="highlights-grid">
					{highlights.map((h) => (
						<HighlightCard title={h.title} description={h.description} />
					))}
				</div>
			</section>
		</main>
	</div>
</Layout>

<style>
	.main-content {
		display: flex;
		flex-direction: column;
		gap: 3rem;
	}

	.bio-hero {
		padding: 3rem;
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}

  .tagline {
    font-size: 2rem;
    font-weight: 800;
    line-height: 1.2;
    background: var(--accent-gradient);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    margin-bottom: 0.5rem;
  }

  .bio-content {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

	.bio-paragraph {
		font-size: 1.15rem;
		line-height: 1.8;
		color: var(--text-primary);
		font-weight: 400;
	}

	.hero-context {
		font-size: 1rem;
		line-height: 1.7;
		color: var(--text-secondary);
		padding: 1.5rem;
		border-left: 4px solid var(--accent-teal);
		background: rgba(13, 148, 136, 0.05);
		border-radius: 0 1rem 1rem 0;
	}

	.hero-actions {
		display: flex;
		gap: 1rem;
		flex-wrap: wrap;
	}

  .highlights-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1.5rem;
  }

	.interests-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
		gap: 1.5rem;
	}

	.interest-item {
		padding: 1.5rem;
		display: flex;
		align-items: center;
		gap: 1rem;
    transition: transform 0.3s ease;
	}

  .interest-item:hover {
    transform: translateX(8px);
    border-color: var(--accent-teal);
  }

	.honors-container {
		display: flex;
		flex-direction: column;
		gap: 2rem;
	}

	.sub-title {
		font-size: 1.25rem;
		color: var(--accent-sky);
		margin-bottom: 1rem;
		text-transform: uppercase;
		letter-spacing: 0.1em;
	}

	.honor-list {
		list-style: none;
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
	}

	.honor-list li {
		padding-left: 1.25rem;
		position: relative;
    color: var(--text-secondary);
	}

	.honor-list li::before {
		content: "•";
		color: var(--accent-teal);
		position: absolute;
		left: 0;
		font-weight: bold;
	}

  .two-column-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
  }

  .cert-list, .service-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .cert-list li, .service-list li {
    padding: 1rem 1.25rem;
    font-size: 0.95rem;
    color: var(--text-secondary);
    border-radius: 0.75rem;
  }

	@media (max-width: 1024px) {
    .two-column-grid { grid-template-columns: 1fr; }
		.bio-hero { padding: 2rem 1.5rem; }
		.bio-text { font-size: 1rem; }
    .hero-actions { flex-direction: column; }
	}
</style>
