---
import Layout from '../layouts/Layout.astro';
import Sidebar from '../components/Sidebar.astro';
import QuickNav from '../components/QuickNav.astro';
import HighlightCard from '../components/HighlightCard.astro';
import { cv } from '../data/cv';

const { tagline, bio, heroText, highlights, experience, additionalProjects, publications, honors } = cv;
---

<Layout title="Home">
  <!-- Independent Floating Navigation Widget -->
  <QuickNav />

	<div class="page-layout container">
    <!-- Sticky Personal Info Sidebar -->
    <Sidebar />

		<main class="main-content">
      <!-- Biography & Highlights -->
			<section id="bio" style="padding-top: 0;">
				<div class="bio-hero glass" style="margin-top: 0;">
          <h1 class="tagline">{tagline}</h1>
          <div class="bio-content">
            <p class="bio-paragraph">
              Driven by the vision of making AI truly useful in healthcare, my research focuses on translational medical AI that can move beyond algorithm development into real clinical practice. I am currently pursuing a Direct Ph.D. in Biomedical Engineering at National Yang Ming Chiao Tung University (NYCU), with an emphasis on medical image analysis, multimodal AI, and standards-based clinical integration through DICOM, DICOMweb, and FHIR. My goal is to develop trustworthy AI systems that can be seamlessly integrated into hospital workflows, reduce clinical burden, and help patients receive timely and effective care.
            </p>
          </div>
          <div class="hero-context">Bridging AI Model Development and Standards-Based Clinical Integration for Seamless Adoption</div>
          <div class="hero-actions">
            <a href="#research" class="btn btn-primary">View Clinical Systems & Research</a>
            <a href="/publications" class="btn btn-outline">View Academic CV</a>
          </div>
        </div>

        <div class="highlights-section mt-12">
          <div class="highlights-grid">
            {highlights.map((h) => (
              <HighlightCard title={h.title} description={h.description} />
            ))}
          </div>
        </div>
			</section>

      <!-- Full Research Portfolio -->
      <section id="research" class="section-spacing">
        <h2 class="section-title">Ph.D. Research Portfolio</h2>
        <div class="exp-list">
          {experience[0].projects.map((proj) => (
            <div class="flagship-card">
              <div class="flagship-ribbon">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg>
                Ph.D. Research Flagship
              </div>
              <div class="flagship-body p-6">
                <h3 class="flagship-title mb-4">{proj.title}</h3>
                <p class="flagship-description">{proj.description}</p>
              </div>
            </div>
          ))}
        </div>
      </section>

      <!-- Full Clinical Systems -->
      <section id="projects" class="section-spacing">
        <h2 class="section-title">Clinical System Deployment</h2>
        <div class="exp-list">
          {additionalProjects.map((proj) => (
            <div class="flagship-card">
              <div class="flagship-ribbon">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4.8 2.3A.3.3 0 1 0 5 2l-.2.3ZM7 2a3 3 0 1 0-3 3"></path><path d="M5.9 4.7a3 3 0 1 0 3 3"></path><path d="M11.8 5.2V10a8 8 0 0 1-8 8"></path></svg>
                Clinical Collaborative Project
              </div>
              <div class="flagship-body p-6">
                <h3 class="flagship-title mb-4">{proj.title}</h3>
                <p class="flagship-description">{proj.description}</p>
              </div>
            </div>
          ))}
        </div>
      </section>

      <div class="two-column-grid section-spacing">
        <section id="honors" class="honors-summary">
          <h2 class="section-title">Honors & Patents</h2>
          <div class="list">
             {honors.map((group) => (
                <div class="item-card glass">
                  <h3 class="item-title">{group.category}</h3>
                  <ul class="item-list">
                    {group.items.map((item) => (
                      <li class={item.includes("National") || item.includes("NSTC") ? "list-node kw-honor" : "list-node"}>• {item}</li>
                    ))}
                  </ul>
                </div>
             ))}
             <div class="item-card glass">
               <h3 class="item-title">Patents</h3>
               <ul class="item-list">
                 {cv.patents.map((item) => (
                   <li class="list-node">• {item.title} <span class="kw-clinical">({item.status})</span></li>
                 ))}
               </ul>
             </div>
          </div>
        </section>

        <section class="publications-summary">
          <h2 class="section-title">Publications & Presentations</h2>
          <div class="list">
            <h3 class="item-title mb-spacing">Journal Papers</h3>
            {publications.journals.map((pub) => (
              <div class="paper-card glass">
                <h3 class="paper-title">{pub.title}</h3>
                <p class="paper-meta">{pub.venue} • {pub.status} • {pub.role}</p>
              </div>
            ))}
            <h3 class="item-title mt-spacing mb-spacing">Conference Papers</h3>
            {publications.conferences.map((pub) => (
              <div class="paper-card glass">
                <h3 class="paper-title">{pub.title}</h3>
                <p class="paper-meta">{pub.venue} • {pub.type} • {pub.role}</p>
              </div>
            ))}
          </div>
        </section>
      </div>
		</main>
	</div>
</Layout>

<style>
  .two-column-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
  }
  @media (max-width: 1200px) {
    .two-column-grid { grid-template-columns: 1fr; }
  }
</style>
