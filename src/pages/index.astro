---
import Layout from '../layouts/Layout.astro';
import Sidebar from '../components/Sidebar.astro';
import QuickNav from '../components/QuickNav.astro';
import HighlightCard from '../components/HighlightCard.astro';
import { cv } from '../data/cv';

const { tagline, bio, heroText, highlights, experience, additionalProjects, publications, honors } = cv;
---

<Layout title="Home">
  <!-- Independent Floating Navigation Widget -->
  <QuickNav />

	<div class="page-layout container">
    <!-- Sticky Personal Info Sidebar -->
    <Sidebar />

		<main class="main-content">
      <!-- Biography & Highlights -->
			<section id="bio" class="section-spacing">
				<div class="bio-hero glass">
          <h1 class="tagline">{tagline}</h1>
          <div class="bio-content">
            <p class="bio-paragraph">
              Focused on translational medical AI, with the goal of developing technologies that can be seamlessly integrated into real clinical workflows. Currently pursuing a Direct Ph.D. in Biomedical Engineering at NYCU.
            </p>
          </div>
          <p class="hero-context">{heroText}</p>
        </div>

        <div class="highlights-section mt-12">
          <div class="highlights-grid">
            {highlights.map((h) => (
              <HighlightCard title={h.title} description={h.description} />
            ))}
          </div>
        </div>
			</section>

      <!-- Dashboard Sections - Summary Only -->
      
      <section id="research" class="dashboard-section section-spacing">
        <h2 class="section-title">Featured Research</h2>
        <div class="summary-list">
          {experience[0].projects.slice(0, 2).map((proj) => (
            <div class="flagship-card condensed">
              <div class="flagship-ribbon">Ph.D. Research Flagship</div>
              <div class="flagship-body p-6">
                <h3 class="text-primary font-bold text-lg mb-2">{proj.title}</h3>
                <p class="text-secondary text-sm line-clamp-2">{proj.description}</p>
              </div>
            </div>
          ))}
        </div>
        <a href="/experience" class="view-more-btn">Explore Full Research Portfolio (6 Projects) →</a>
      </section>

      <section id="projects" class="dashboard-section section-spacing">
        <h2 class="section-title">Clinical System Deployment</h2>
        <div class="summary-list">
          {additionalProjects.slice(0, 2).map((proj) => (
            <div class="flagship-card condensed">
              <div class="flagship-ribbon">Clinical Collaborative Project</div>
              <div class="flagship-body p-6">
                <h3 class="text-primary font-bold text-lg mb-2">{proj.title}</h3>
                <p class="text-secondary text-sm line-clamp-2">{proj.description}</p>
              </div>
            </div>
          ))}
        </div>
        <a href="/projects" class="view-more-btn">View All Clinical Implementations (7+ Projects) →</a>
      </section>

      <div class="two-column-grid section-spacing">
        <section id="honors" class="honors-summary">
          <h2 class="section-title">Key Distinctions</h2>
          <div class="list">
             <div class="glass p-6 border-l-4 border-gold">
               <div class="badge-honor">National Level Honor</div>
               <p class="text-gold font-bold">NSTC Research & Creative Award (2023)</p>
             </div>
             <div class="glass p-6 border-l-4 border-teal">
               <div class="badge-honor">Medical Device Clearance</div>
               <p class="text-teal font-bold">DeepBT Detector Plus (TFDA Cleared)</p>
             </div>
          </div>
          <a href="/honors" class="view-more-btn mt-6">View Honors, Patents & Service →</a>
        </section>

        <section class="publications-summary">
          <h2 class="section-title">Latest Publications</h2>
          <div class="list">
            {publications.journals.slice(0, 1).map((pub) => (
              <div class="summary-card glass">
                <h3 class="text-primary text-sm font-bold">{pub.title}</h3>
                <p class="text-sky text-xs mt-2">{pub.venue} • {pub.status}</p>
              </div>
            ))}
          </div>
          <a href="/publications" class="view-more-btn mt-6">View All Papers & Presentations →</a>
        </section>
      </div>
		</main>
	</div>
</Layout>

<style>
  .condensed { margin-bottom: 1.5rem; }
  .two-column-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
  }
  @media (max-width: 1200px) {
    .two-column-grid { grid-template-columns: 1fr; }
  }
</style>
