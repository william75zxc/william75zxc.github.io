---
import Layout from '../layouts/Layout.astro';
import Sidebar from '../components/Sidebar.astro';
import QuickNav from '../components/QuickNav.astro';
import HighlightCard from '../components/HighlightCard.astro';
import { cv } from '../data/cv';

const { tagline, bio, heroText, highlights, researchVision, experience, additionalProjects, publications, honors } = cv;
---

<Layout title="Home">
  <!-- Independent Floating Navigation Widget -->
  <QuickNav />

	<div class="page-layout container">
    <!-- Sticky Personal Info Sidebar -->
    <Sidebar />

		<main class="main-content">
      <!-- Biography & Highlights -->
			<section id="bio" style="padding-top: 0;">
				<div class="bio-hero glass" style="margin-top: 0;">
          <h1 class="tagline">{tagline}</h1>
          <div class="bio-content">
            <p class="bio-paragraph">
              Driven by the vision of making AI truly useful in healthcare, my research focuses on translational medical AI that can move beyond algorithm development into real clinical practice. I am currently pursuing a Direct Ph.D. in Biomedical Engineering at National Yang Ming Chiao Tung University (NYCU), with an emphasis on medical image analysis, multimodal AI, and standards-based clinical integration through DICOM, DICOMweb, and FHIR. My goal is to develop trustworthy AI systems that can be seamlessly integrated into hospital workflows, reduce clinical burden, and help patients receive timely and effective care.
            </p>
          </div>
          <div class="hero-actions">
            <a href="#research" class="btn btn-primary">View Portfolio</a>
            <a href="/cv" class="btn btn-outline">Academic CV Page</a>
            <a href={cv.cvPdf} download class="btn btn-outline" style="border-color: gold; color: gold; display: inline-flex; align-items: center; gap: 0.5rem;">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
              Download PDF
            </a>
            <a href="#contact" class="btn btn-outline" style="border-color: var(--accent-teal); color: var(--accent-teal);">Contact Me</a>
          </div>
        </div>

        <div class="highlights-section mt-12">
          <div class="highlights-grid">
            {highlights.map((h) => (
              <HighlightCard title={h.title} description={h.description} />
            ))}
          </div>
        </div>
			</section>

      <!-- Full Research Portfolio -->
      <section id="research" class="section-spacing">
        <h2 class="section-title">Ph.D. Research Portfolio</h2>
        <div class="exp-list">
          {experience[0].projects.map((proj) => (
            <div class="flagship-card">
              <div class="flagship-ribbon">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg>
                Ph.D. Research Flagship
              </div>
              <div class="flagship-body p-6">
                <h3 class="flagship-title mb-4">{proj.title}</h3>
                <p class="flagship-description">{proj.description}</p>
              </div>
            </div>
          ))}
        </div>
        <div style="margin-top: 3rem; text-align: center;">
          <a href="/research" class="btn btn-outline" style="border-width: 2px; padding: 0.8rem 2.5rem; font-weight: 700; border-color: var(--accent-sky); color: var(--accent-sky);">View Full Research Portfolio →</a>
        </div>
      </section>

      <!-- Full Clinical Systems -->
      <section id="projects" class="section-spacing">
        <h2 class="section-title">Clinical System Deployment</h2>
        <div class="exp-list">
          {additionalProjects.map((proj) => (
            <div class="flagship-card">
              <div class="flagship-ribbon">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4.8 2.3A.3.3 0 1 0 5 2l-.2.3ZM7 2a3 3 0 1 0-3 3"></path><path d="M5.9 4.7a3 3 0 1 0 3 3"></path><path d="M11.8 5.2V10a8 8 0 0 1-8 8"></path></svg>
                Clinical Collaborative Project
              </div>
              <div class="flagship-body p-6">
                <h3 class="flagship-title mb-4">{proj.title}</h3>
                <p class="flagship-description">{proj.description}</p>
              </div>
            </div>
          ))}
        </div>
        <div style="margin-top: 3rem; text-align: center;">
          <a href="/clinical-systems" class="btn btn-outline" style="border-width: 2px; padding: 0.8rem 2.5rem; font-weight: 700; border-color: var(--accent-teal); color: var(--accent-teal);">Explore Deployment Details →</a>
        </div>
      </section>

      <!-- Publications Section -->
      <section id="publications" class="section-spacing">
        <h2 class="section-title">Publications & Presentations</h2>
        
        <h3 class="item-title mb-spacing" style="color: var(--accent-sky);">Journal Papers</h3>
        <div class="card-grid">
          {publications.journals.map((pub) => (
            <div class="award-card glass" style="border-left: 4px solid var(--accent-sky); margin-bottom: 0;">
              <div style="display: flex; justify-content: space-between; align-items: flex-start; gap: 1rem;">
                <div>
                  <h3 class="paper-title" style="font-size: 1.15rem; font-weight: 700; color: var(--text-primary); line-height: 1.4;">{pub.title}</h3>
                  <p class="paper-meta" style="font-size: 0.9rem; color: var(--accent-sky); font-weight: 600; margin-top: 0.5rem;">{pub.venue} • {pub.status}</p>
                </div>
                <span class="badge" style="background: rgba(56, 189, 248, 0.1); color: var(--accent-sky); border: 1px solid rgba(56, 189, 248, 0.2); font-size: 0.7rem; padding: 0.2rem 0.6rem; border-radius: 1rem; text-transform: uppercase;">Journal</span>
              </div>
            </div>
          ))}
        </div>

        <h3 class="item-title mb-spacing" style="color: var(--accent-gold); margin-top: 2rem;">Conference Proceedings</h3>
        <div class="card-grid">
          {publications.conferences.map((pub) => (
            <div class="award-card glass" style={`border-left: 4px solid ${pub.type.includes('Oral') ? 'var(--accent-gold)' : pub.type.includes('Poster') ? '#c084fc' : 'rgba(255,255,255,0.2)'}; margin-bottom: 0;`}>
              <div style="display: flex; justify-content: space-between; align-items: flex-start; gap: 1rem;">
                <div>
                  <h3 class="paper-title" style="font-size: 1.15rem; font-weight: 700; color: var(--text-primary); line-height: 1.4;">{pub.title}</h3>
                  <p class="paper-meta" style={`font-size: 0.9rem; font-weight: 600; margin-top: 0.5rem; color: ${pub.type.includes('Oral') ? 'var(--accent-gold)' : 'var(--text-secondary)'};`}>
                    {pub.venue} • {pub.type}
                  </p>
                </div>
                {pub.type.includes('Oral') ? (
                  <span class="badge" style="background: rgba(250, 204, 21, 0.15); color: #facc15; border: 1px solid rgba(250, 204, 21, 0.3); font-size: 0.7rem; padding: 0.2rem 0.6rem; border-radius: 1rem; font-weight: 800; text-transform: uppercase;">Oral</span>
                ) : pub.type.includes('Poster') ? (
                  <span class="badge" style="background: rgba(168, 85, 247, 0.15); color: #c084fc; border: 1px solid rgba(168, 85, 247, 0.3); font-size: 0.7rem; padding: 0.2rem 0.6rem; border-radius: 1rem; font-weight: 800; text-transform: uppercase;">Poster</span>
                ) : (
                  <span class="badge" style="background: rgba(255, 255, 255, 0.05); color: var(--text-secondary); border: 1px solid rgba(255, 255, 255, 0.1); font-size: 0.7rem; padding: 0.2rem 0.6rem; border-radius: 1rem; text-transform: uppercase;">{pub.type}</span>
                )}
              </div>
            </div>
          ))}
        </div>

        <div style="margin-top: 2.5rem; text-align: center;">
          <a href="/publications" class="btn btn-outline" style="border-width: 2px; padding: 0.8rem 2.5rem; font-weight: 700; border-color: var(--accent-sky); color: var(--accent-sky);">View Dedicated Publications Page →</a>
        </div>
      </section>

      <!-- Honors Section -->
      <section id="honors" class="section-spacing">
        <h2 class="section-title">Honors & Patents</h2>
        {honors.map((group, index) => (
          <>
            <h3 class={`item-title mb-spacing ${index > 0 ? "mt-spacing" : ""}`}>{group.category}</h3>
            <div class="card-grid">
              {group.items.map((item) => (
                <div class="award-card glass" style="margin-bottom: 0;">
                  <div class="award-icon" style={group.category === "Awards" ? "color: var(--accent-gold); background: rgba(245, 158, 11, 0.15);" : "color: var(--accent-sky); background: rgba(56, 189, 248, 0.15);"}>
                    {group.category === "Awards" ? (
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"></path><path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"></path><path d="M4 22h16"></path><path d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22"></path><path d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22"></path><path d="M18 2H6v7a6 6 0 0 0 12 0V2Z"></path></svg>
                    ) : (
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
                    )}
                  </div>
                  <div class="award-content">
                    {typeof item === 'string' ? (
                      <p class={group.category === "Awards" && !item.includes("Shortlisted") ? "award-title text-gold" : "award-title"}>{item}</p>
                    ) : (
                      <a href={item.url} target="_blank" class="award-title hover-link" style="text-decoration: none; display: flex; flex-direction: column; gap: 0.75rem;">
                        <span class={group.category === "Awards" && !item.text.includes("Shortlisted") ? "text-gold" : ""}>{item.text}</span>
                        <div class="link-pill" style="display: inline-flex; align-items: center; gap: 0.5rem; background: rgba(56, 189, 248, 0.15); border: 1px solid rgba(56, 189, 248, 0.3); padding: 0.4rem 1rem; border-radius: 2rem; width: fit-content; transition: all 0.3s ease;">
                          <span style="font-size: 0.75rem; font-weight: 700; color: var(--accent-sky); letter-spacing: 0.05em;">VIEW SESSION</span>
                          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" style="color: var(--accent-sky);"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path><polyline points="15 3 21 3 21 9"></polyline><line x1="10" y1="14" x2="21" y2="3"></line></svg>
                        </div>
                      </a>
                    )}
                  </div>
                </div>
              ))}
            </div>
            
            {group.category === "Awards" && (
              <>
                <h3 class="item-title mt-spacing mb-spacing">Patents</h3>
                <div class="card-grid">
                  {cv.patents.map((item) => (
                    <div class="award-card glass" style="margin-bottom: 0;">
                      <div class="award-icon" style="color: var(--accent-teal); background: rgba(13, 148, 136, 0.15);">
                          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 14c.2-1 .7-1.7 1.5-2.5 1-.9 1.5-2.2 1.5-3.5A6 6 0 0 0 6 8c0 1 .2 2.2 1.5 3.5.7.9 1.2 1.5 1.5 2.5"></path><path d="M9 18h6"></path><path d="M10 22h4"></path></svg>
                      </div>
                      <div class="award-content">
                        <h3 class="award-title">{item.title}</h3>
                        <p class="paper-meta">{item.status}</p>
                      </div>
                    </div>
                  ))}
                </div>
              </>
            )}
          </>
        ))}
      </section>
    </main>
	</div>

  <!-- Contact Section - Truly Broken Out to Full Width -->
  <section id="contact" class="section-spacing container">
    <h2 class="section-title">CONTACT ME</h2>
    <div class="exp-list">
      <div class="flagship-card glass">
        <div class="flagship-ribbon">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
          CONTACT INFORMATION
        </div>
        <div class="flagship-body p-8">
          <h3 class="flagship-title mb-4">Direct Communication & Research Inquiries</h3>
          <p class="flagship-description mb-8">
            I am always open to discussing research collaborations, professional opportunities, or clinical AI integration projects. Feel free to reach out via the following channels:
          </p>
          <div style="display: flex; flex-direction: column; gap: 1.5rem;">
              <div class="contact-item-row-horizontal">
                <span class="contact-label-wide text-gradient" style="min-width: 180px;">EMAIL ADDRESS</span>
                <span class="contact-divider">:</span>
                <a href={`mailto:${cv.email}`} class="contact-value" style="color: var(--text-primary); text-decoration: none;">{cv.email}</a>
              </div>
              <div class="contact-item-row-horizontal">
                <span class="contact-label-wide text-gradient" style="min-width: 180px;">MOBILE PHONE</span>
                <span class="contact-divider">:</span>
                <span class="contact-value">{cv.phone}</span>
              </div>
          </div>
          <div style="margin-top: 3.5rem;">
            <a href={`mailto:${cv.email}`} class="btn btn-primary" style="padding: 1rem 3rem;">Send Email Directly</a>
          </div>
        </div>
      </div>
    </div>
  </section>

</Layout>

<style is:global>
  .site-footer {
    margin-top: 6rem;
    padding: 3rem 0;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    background: rgba(10, 15, 28, 0.5);
  }

  .footer-content {
    display: flex;
    justify-content: space-between;
    align-items: center;
    color: var(--text-secondary);
    font-size: 0.9rem;
  }

  .copyright {
    color: var(--text-primary);
    font-weight: 600;
    margin-bottom: 0.25rem;
  }

  .credit {
    font-size: 0.8rem;
    opacity: 0.7;
  }

  .footer-link {
    color: var(--accent-sky);
    text-decoration: none;
    font-weight: 600;
    transition: color 0.2s ease;
  }

  .footer-link:hover {
    color: var(--text-primary);
  }

  @media (max-width: 768px) {
    .footer-content {
      flex-direction: column;
      text-align: center;
      gap: 1.5rem;
    }
  }

  .two-column-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
  }
  
  .card-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }
  @media (max-width: 900px) {
    .card-grid {
      grid-template-columns: 1fr;
    }
  }

  .contact-item-row {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  /* Horizontal Contact Style */
  .contact-item-row-horizontal {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.5rem 0;
  }

  .contact-label-wide {
    font-size: 0.75rem;
    font-weight: 800;
    color: var(--text-secondary);
    letter-spacing: 0.1em;
    min-width: 140px; /* Ensures alignment */
  }

  .contact-divider {
    color: var(--accent-sky);
    font-weight: 800;
  }

  .contact-value {
    font-size: 1.1rem;
    font-weight: 700;
    word-break: break-all;
  }

  @media (max-width: 768px) {
    .contact-item-row-horizontal {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.25rem;
    }
    .contact-divider { display: none; }
  }

  @media (max-width: 1200px) {
    .two-column-grid { grid-template-columns: 1fr; }
  }
</style>
