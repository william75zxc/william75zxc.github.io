---
import Layout from '../layouts/Layout.astro';
import Sidebar from '../components/Sidebar.astro';
import HighlightCard from '../components/HighlightCard.astro';
import { cv } from '../data/cv';

const { highlights, bio, heroText, tagline } = cv;
---

<Layout title="Home">
	<div class="container page-layout">
		<Sidebar />
		
		<main class="main-content">
			<section class="bio-hero glass">
        <h2 class="tagline">{tagline}</h2>
				<div class="bio-content">
          {bio.split('\n\n').map((p) => (
            <p class="bio-paragraph">{p}</p>
          ))}
        </div>
        <p class="hero-context">{heroText}</p>
				<div class="hero-actions">
					<a href="/experience" class="btn btn-primary">View Clinical Systems & Research</a>
					<a href="/cv.pdf" class="btn btn-outline" target="_blank">View Academic CV</a>
				</div>
			</section>

			<section class="highlights-section">
				<div class="highlights-grid">
					{highlights.map((h) => (
						<HighlightCard title={h.title} description={h.description} />
					))}
				</div>
			</section>

			<section class="research-summary">
				<h2 class="section-title">Research Interests</h2>
				<div class="interests-grid">
					{cv.researchInterests.map((interest) => (
						<div class="interest-item glass">
							<span class="dot"></span>
							<p>{interest}</p>
						</div>
					))}
				</div>
			</section>
		</main>
	</div>
</Layout>

<style>
	.main-content {
		display: flex;
		flex-direction: column;
		gap: 3rem;
	}

	.bio-hero {
		padding: 3rem;
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}

  .tagline {
    font-size: 2rem;
    font-weight: 800;
    line-height: 1.2;
    background: var(--accent-gradient);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    margin-bottom: 0.5rem;
  }

  .bio-content {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

	.bio-paragraph {
		font-size: 1.15rem;
		line-height: 1.8;
		color: var(--text-primary);
		font-weight: 400;
	}

	.hero-context {
		font-size: 1rem;
		line-height: 1.7;
		color: var(--text-secondary);
		padding: 1.5rem;
		border-left: 4px solid var(--accent-teal);
		background: rgba(13, 148, 136, 0.05);
		border-radius: 0 1rem 1rem 0;
	}

	.hero-actions {
		display: flex;
		gap: 1rem;
		flex-wrap: wrap;
	}

  .highlights-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1.5rem;
  }

	.interests-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
		gap: 1.5rem;
	}

	.interest-item {
		padding: 1.5rem;
		display: flex;
		align-items: center;
		gap: 1rem;
    transition: transform 0.3s ease;
	}

  .interest-item:hover {
    transform: translateX(8px);
    border-color: var(--accent-teal);
  }

	.dot {
		width: 10px;
		height: 10px;
		background: var(--accent-gradient);
		border-radius: 50%;
		flex-shrink: 0;
	}

	@media (max-width: 768px) {
		.bio-hero { padding: 2rem 1.5rem; }
		.bio-text { font-size: 1rem; }
    .hero-actions { flex-direction: column; }
	}
</style>
