---
import Layout from '../layouts/Layout.astro';
import PublicationCard from '../components/PublicationCard.astro';
import { cv } from '../data/cv';

const { journals, conferences } = cv.publications;
---

<Layout title="Publications">
	<section class="container">
		<h1 class="section-title">Selected Publications & Presentations</h1>
		
		<div class="category">
			<h2 class="sub-title">Journal Papers</h2>
			<div class="list">
				{journals.map((pub) => (
					<div class="paper-card glass">
            <h3 class="paper-title">{pub.title}</h3>
            <p class="paper-meta">{pub.venue} • {pub.status} • {pub.year} • {pub.role}</p>
					</div>
				))}
			</div>
		</div>

		<div class="category">
			<h2 class="sub-title">Conference Papers & Presentations</h2>
			<div class="list">
				{conferences.map((pub) => (
					<div class="paper-card glass">
            <h3 class="paper-title">{pub.title}</h3>
            <p class="paper-meta">{pub.venue} • {pub.type} • {pub.year} • {pub.role}</p>
					</div>
				))}
			</div>
		</div>

		<div class="category">
			<h2 class="sub-title">Patents</h2>
			<div class="list">
				{cv.patents.map((patent) => (
               <div class="award-card glass">
                 <div class="award-icon" style="color: var(--accent-teal); background: rgba(13, 148, 136, 0.15);">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 14c.2-1 .7-1.7 1.5-2.5 1-.9 1.5-2.2 1.5-3.5A6 6 0 0 0 6 8c0 1 .2 2.2 1.5 3.5.7.9 1.2 1.5 1.5 2.5"></path><path d="M9 18h6"></path><path d="M10 22h4"></path></svg>
                 </div>
                 <div class="award-content">
                   <h3 class="award-title">{patent.title}</h3>
                   <p class="paper-meta">{patent.status}</p>
                 </div>
               </div>
				))}
			</div>
		</div>

    {cv.publications.presentations && (
      <div class="category">
        <h2 class="sub-title">Conference Presentations</h2>
        <div class="list">
          {cv.publications.presentations.map((pres) => (
            <div class="paper-card glass">
              <h3 class="paper-title">{pres.event}</h3>
              <p class="paper-meta">{pres.role}</p>
            </div>
          ))}
        </div>
      </div>
    )}
	</section>
</Layout>

<style>
	.category {
		margin-bottom: 4rem;
	}
	.sub-title {
		font-size: 1.75rem;
		margin-bottom: 1.5rem;
		color: var(--accent-teal);
		border-left: 4px solid var(--accent-teal);
		padding-left: 1rem;
	}
	.list {
		display: grid;
		grid-template-columns: 1fr;
		gap: 1.5rem;
	}
	.patent-card {
		padding: 1.5rem;
		border-left: 4px solid var(--accent-sky);
	}
	.patent-card h3 {
		font-size: 1.2rem;
		margin-bottom: 0.5rem;
	}
	.patent-card p {
		color: var(--text-secondary);
		font-size: 0.9rem;
	}
</style>
