---
import Layout from '../layouts/Layout.astro';
import { cv } from '../data/cv';

const { experience } = cv;
---

<Layout title="Experience">
	<section class="container">
		<h1 class="section-title">Research & Project Experience</h1>
		
		<div class="exp-list">
			{experience.map((exp) => (
				<div class="exp-item">
					<div class="exp-header glass">
						<div class="exp-title">
							<h2>{exp.role}</h2>
							<p class="institution">{exp.institution}</p>
							{exp.advisor && <p class="advisor">Advisor: {exp.advisor}</p>}
						</div>
						<span class="period">{exp.period}</span>
					</div>
					
					<div class="projects">
						{exp.projects.map((project) => (
							<div class="project-card glass">
								<div class="project-header">
									<h3>{project.title}</h3>
									<span class="project-period">{project.period}</span>
								</div>
								<p class="description">{project.description}</p>
							</div>
						))}
					</div>
				</div>
			))}
		</div>

    {cv.additionalProjects && (
      <div class="additional-experience container">
        <h2 class="section-title">Additional Project Experience</h2>
        <div class="additional-grid">
          {cv.additionalProjects.map((proj) => (
            <div class="glass additional-card">
              <h3>{proj.title}</h3>
              <p>{proj.description}</p>
            </div>
          ))}
        </div>
      </div>
    )}
	</section>
</Layout>

<style>
	.exp-list {
		display: flex;
		flex-direction: column;
		gap: 3rem;
    margin-bottom: 4rem;
	}
	.exp-header {
		padding: 2rem;
		display: flex;
		justify-content: space-between;
		align-items: flex-start;
		margin-bottom: 2rem;
		border-left: 4px solid var(--accent-teal);
	}
	.exp-title h2 {
		font-size: 1.75rem;
		color: var(--text-primary);
		margin-bottom: 0.25rem;
	}
	.institution {
		font-size: 1.1rem;
		color: var(--accent-sky);
		font-weight: 500;
	}
	.advisor {
		font-size: 0.95rem;
		color: var(--text-secondary);
		margin-top: 0.5rem;
	}
	.projects {
		display: grid;
		grid-template-columns: 1fr;
		gap: 1.5rem;
	}
	.project-card {
		padding: 1.5rem;
		border-radius: 0.75rem;
	}
	.project-header {
		display: flex;
		justify-content: space-between;
		align-items: flex-start;
		margin-bottom: 1rem;
		gap: 1rem;
	}
	.project-header h3 {
		font-size: 1.25rem;
		color: var(--text-primary);
	}
	.project-period {
		font-size: 0.875rem;
		color: var(--text-secondary);
		white-space: nowrap;
	}
	.description {
		color: var(--text-secondary);
		line-height: 1.7;
	}
  .additional-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.5rem;
  }
  .additional-card {
    padding: 1.5rem;
  }
  .additional-card h3 {
    font-size: 1.1rem;
    margin-bottom: 0.75rem;
    color: var(--accent-sky);
  }
  .additional-card p {
    font-size: 0.9rem;
    color: var(--text-secondary);
  }

	@media (max-width: 768px) {
		.exp-header {
			flex-direction: column;
			gap: 1rem;
		}
		.project-header {
			flex-direction: column;
			gap: 0.5rem;
		}
	}
</style>
