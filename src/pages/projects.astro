---
import Layout from '../layouts/Layout.astro';
import { cv } from '../data/cv';

const { additionalProjects } = cv;
---

<Layout title="Clinical Systems">
	<section class="container">
		<h1 class="section-title">Clinical Systems & Deployment</h1>
    <p class="section-intro">Standards-based systems and collaborative developments integrated within real-world healthcare workflows.</p>
		
		<div class="projects-list">
			{additionalProjects.map((project) => (
				<div class="flagship-card">
          <div class="flagship-ribbon">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4.8 2.3A.3.3 0 1 0 5 2l-.2.3ZM7 2a3 3 0 1 0-3 3"></path><path d="M5.9 4.7a3 3 0 1 0 3 3"></path><path d="M11.8 5.2V10a8 8 0 0 1-8 8"></path></svg>
            Clinical System Deployment
          </div>
          <div class="flagship-body">
            <div class="flagship-tags">
              <span class="tag-pill">Collaborative Project</span>
              <span class="tag-pill">Clinically Deployed</span>
            </div>
            <h3 class="flagship-title">{project.title}</h3>
            <p class="flagship-description">{project.description}</p>
          </div>
				</div>
			))}
		</div>
	</section>
</Layout>

<style>
  .section-intro {
    font-size: 1.15rem;
    color: var(--text-secondary);
    margin-bottom: 3rem;
    max-width: 800px;
  }
	.projects-list {
		display: grid;
		grid-template-columns: 1fr;
		gap: 2rem;
	}
</style>
