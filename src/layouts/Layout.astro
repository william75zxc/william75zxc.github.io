---
import '../styles/global.css';
import { cv } from '../data/cv';

interface Props {
	title: string;
	description?: string;
}

const { title, description = "Jing-Jhong (William) Chen - Ph.D. Student in Biomedical Engineering" } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title} | {cv.name}</title>
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Outfit:wght@500;600;700;800&display=swap" rel="stylesheet">
	</head>
	<body>
		<header class="glass sticky-nav">
			<nav class="container nav-wrapper">
				<a href="/" class="logo">{cv.name}</a>
				<ul class="nav-links">
						<li><a href="/" class="nav-link">Home</a></li>
						<li><a href="/cv" class="nav-link">CV</a></li>
						<li><a href="/experience" class="nav-link">Research Portfolio</a></li>
						<li><a href="/projects" class="nav-link">Clinical Systems</a></li>
						<li><a href="/honors" class="nav-link">Honors & Patents</a></li>
						<li><a href="/publications" class="nav-link">Publications</a></li>
				</ul>
			</nav>
		</header>
		<main>
			<slot />
		</main>
		<footer class="site-footer">
			<div class="container">
				<div class="footer-content">
					<div class="footer-left">
						<p class="copyright">© 2026 {cv.name}. All rights reserved.</p>
						<p class="credit">Powered by Astro & Glassmorphism Design</p>
					</div>
					<div class="footer-right">
						<a href="#bio" class="footer-link">Back to Top</a>
					</div>
				</div>
			</div>
		</footer>
	</body>
</html>

<style is:global>
  .site-footer {
    margin-top: 6rem;
    padding: 3rem 0;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    background: rgba(10, 15, 28, 0.5);
  }

  .footer-content {
    display: flex;
    justify-content: space-between;
    align-items: center;
    color: var(--text-secondary);
    font-size: 0.9rem;
  }

  .copyright {
    color: var(--text-primary);
    font-weight: 600;
    margin-bottom: 0.25rem;
  }

  .credit {
    font-size: 0.8rem;
    opacity: 0.7;
  }

  .footer-link {
    color: var(--accent-sky);
    text-decoration: none;
    font-weight: 600;
    transition: color 0.2s ease;
  }

  .footer-link:hover {
    color: var(--text-primary);
  }

  @media (max-width: 768px) {
    .footer-content {
      flex-direction: column;
      text-align: center;
      gap: 1.5rem;
    }
  }
			.sticky-nav {
				position: sticky;
				top: 0;
				z-index: 100;
				margin-bottom: 2rem;
        border-radius: 0 0 1.5rem 1.5rem;
        background: rgba(15, 23, 42, 0.8);
			}
			.nav-wrapper {
				display: flex;
				justify-content: space-between;
				align-items: center;
				height: 4.5rem;
			}
			.logo {
				font-size: 1.25rem;
				font-weight: 800;
				color: var(--accent-sky);
				font-family: var(--font-heading);
			}
			.nav-links {
				display: flex;
				gap: 2rem;
				list-style: none;
        font-weight: 600;
        font-size: 0.9rem;
			}
			.footer {
				padding: 4rem 2rem;
				text-align: center;
				color: var(--text-secondary);
				border-top: 1px solid var(--border-color);
        font-size: 0.9rem;
			}
      @media (max-width: 768px) {
        .logo { display: none; }
        .nav-wrapper { justify-content: center; }
      }
		</style>
	</body>
</html>
