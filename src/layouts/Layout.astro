---
import '../styles/global.css';
import { cv } from '../data/cv';

interface Props {
	title: string;
	description?: string;
}

const { title, description = "Jing-Jhong (William) Chen - Ph.D. Student in Biomedical Engineering" } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title} | {cv.name}</title>
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Outfit:wght@500;600;700;800&display=swap" rel="stylesheet">
	</head>
	<body>
		<header class="glass sticky-nav">
			<nav class="container nav-wrapper">
				<a href="/" class="logo">{cv.name}</a>
					<div class="nav-links">
						<a href="/" class="nav-link">Home</a>
						<a href="/publications" class="nav-link">Publications</a>
						<a href="/honors" class="nav-link">Honors & Patents</a>
						<a href="/research" class="nav-link">Research Portfolio</a>
						<a href="/clinical-systems" class="nav-link">Clinical Systems</a>
						<a href="/cv" class="nav-link special-link">CV</a>
					</div>
			</nav>
		</header>
		<main>
			<slot />
		</main>
		<footer class="site-footer">
			<div class="container">
				<div class="footer-content">
					<div class="footer-left">
						<p class="copyright">© 2026 {cv.name}. All rights reserved.</p>
						<p class="credit">Powered by Astro & Glassmorphism Design</p>
					</div>
				</div>
			</div>
		</footer>
	</body>
</html>

<style is:global>
  .site-footer {
    padding: 3rem 0;
    margin-top: 6rem;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    background: rgba(10, 15, 28, 0.4);
    backdrop-filter: blur(8px);
  }

  body {
    padding-bottom: 0;
  }

  .footer-content {
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 100%;
    color: var(--text-secondary);
    font-size: 0.7rem; /* Even smaller */
    letter-spacing: 0.03em;
  }

  .footer-left {
    display: flex;
    gap: 0.75rem;
    align-items: center;
  }

  .copyright {
    color: var(--text-primary);
    font-weight: 700;
    opacity: 0.9;
  }

  .credit {
    opacity: 0.45;
    font-size: 0.65rem;
  }

  .footer-link {
    color: var(--accent-sky);
    text-decoration: none;
    font-weight: 700;
    transition: all 0.2s ease;
    padding: 0.1rem 0.5rem;
    border-radius: 4px;
  }

  .footer-link:hover {
    color: var(--text-primary);
    background: rgba(56, 189, 248, 0.1);
  }

  @media (max-width: 768px) {
    .credit { display: none; }
  }
			.sticky-nav {
				position: sticky;
				top: 0;
				z-index: 100;
				margin-bottom: 2rem;
        border-radius: 0 0 1.5rem 1.5rem;
        background: rgba(15, 23, 42, 0.8);
			}
			.nav-wrapper {
				display: flex;
				justify-content: space-between;
				align-items: center;
				height: 4.5rem;
			}
			.logo {
				font-size: 1.25rem;
				font-weight: 800;
				color: var(--accent-sky);
				font-family: var(--font-heading);
			}
			.nav-links {
				display: flex;
				gap: 2rem;
				list-style: none;
        font-weight: 600;
        font-size: 0.9rem;
			}
			.footer {
				padding: 4rem 2rem;
				text-align: center;
				color: var(--text-secondary);
				border-top: 1px solid var(--border-color);
        font-size: 0.9rem;
			}
      @media (max-width: 768px) {
        .logo { display: none; }
        .nav-wrapper { justify-content: center; }
      }
		</style>
	</body>
</html>
