---
<div class="quick-nav-container">
  <input type="checkbox" id="nav-toggle" class="nav-toggle-input">
  <label for="nav-toggle" class="nav-toggle-btn glass">
    <svg class="icon-menu" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
    <svg class="icon-close" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
  </label>

  <div class="quick-nav-widget glass">
    <a href="/" class="nav-widget-item" title="Home">
      <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg>
    </a>
    <a href="/publications" class="nav-widget-item" title="Publications">
      <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path></svg>
    </a>
    <a href="/honors" class="nav-widget-item" title="Honors & Patents">
      <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="7"></circle><polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"></polyline></svg>
    </a>
    <a href="/research" class="nav-widget-item" title="Research Portfolio">
      <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><circle cx="12" cy="12" r="3"></circle></svg>
    </a>
    <a href="/clinical-systems" class="nav-widget-item" title="Clinical Systems">
      <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"></rect><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"></path></svg>
    </a>
    <a href="/cv" class="nav-widget-item" title="Academic CV">
      <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
    </a>
    <a href="/#bio" class="nav-widget-item" title="Back to Top">
      <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" style="color: var(--accent-gold);"><polyline points="18 15 12 9 6 15"></polyline></svg>
    </a>
  </div>
</div>

<style>
  .quick-nav-container {
    position: fixed;
    bottom: 6.5rem;
    right: 2rem;
    z-index: 1000;
    display: flex;
    flex-direction: column-reverse; /* Toggle button on bottom, Widget above */
    align-items: flex-end; /* Align items to the right edge of the container */
    gap: 0.75rem;
  }

  .nav-toggle-input {
    display: none;
  }

  .nav-toggle-btn {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: var(--accent-sky);
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    box-shadow: 0 4px 20px rgba(0,0,0,0.4);
    background: rgba(15, 23, 42, 0.85);
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  .nav-toggle-btn:hover {
    transform: scale(1.1);
    color: var(--text-primary);
  }

  .nav-toggle-btn svg {
    width: 24px;
    height: 24px;
  }

  .icon-close { display: none; }

  .quick-nav-widget {
    padding: 0.5rem;
    border-radius: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    opacity: 0;
    visibility: hidden;
    transform: translateY(15px) scale(0.9);
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    box-shadow: 0 8px 32px rgba(0,0,0,0.5);
    background: rgba(15, 23, 42, 0.95);
    border: 1px solid rgba(255, 255, 255, 0.1);
    /* Force ignore any inherited positioning from global 'glass' class */
    left: auto !important;
    right: 0 !important;
    position: relative !important;
    margin-right: 0 !important;
  }

  .nav-toggle-input:checked ~ .quick-nav-widget {
    opacity: 1;
    visibility: visible;
    transform: translateY(0) scale(1);
  }

  .nav-toggle-input:checked ~ .nav-toggle-btn {
    background: rgba(56, 189, 248, 0.2);
    transform: rotate(90deg);
  }

  .nav-toggle-input:checked ~ .nav-toggle-btn .icon-menu { display: none; }
  .nav-toggle-input:checked ~ .nav-toggle-btn .icon-close { display: block; }

  .nav-widget-item {
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-secondary);
    text-decoration: none;
    transition: all 0.2s ease;
    border-radius: 50%;
  }

  .nav-widget-item svg {
    flex-shrink: 0;
    color: var(--accent-sky);
    transition: all 0.2s ease;
  }

  .nav-widget-item:hover {
    background: rgba(255, 255, 255, 0.1);
    transform: scale(1.1);
  }

  .nav-widget-item:hover svg {
    color: var(--text-primary);
    filter: drop-shadow(0 0 8px var(--accent-sky));
  }

  /* Responsive adjustment for mobiles */
  @media (max-width: 1024px) {
    .quick-nav-container {
      bottom: 5.5rem;
      right: 1.5rem;
    }
  }
</style>
