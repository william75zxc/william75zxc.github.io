---
import { cv } from '../data/cv';

const { name, title, researchVision, email, phone, location, birthDate, age, profileImage, cvPdf } = cv;
---

<aside class="sidebar-wrapper">
	<div class="sidebar glass sticky-sidebar">
		<div class="profile-section">
      <div class="avatar-container">
			  <img src={profileImage} alt={name} class="avatar" />
      </div>
			<div class="name-section">
				<h1 class="name">{name}</h1>
				<p class="title">{title}</p>
        <p class="vision">{researchVision}</p>
			</div>
		</div>

		<div class="contact-links">
      <div class="contact-item">
        <span class="label">EMAIL</span>
        <a href={`mailto:${email}`} class="value">{email}</a>
      </div>
      <div class="contact-item">
        <span class="label">PHONE</span>
        <span class="value">{phone}</span>
      </div>
      <div class="contact-item">
        <span class="label">LOCATION</span>
        <span class="value">{location}</span>
      </div>
      <div class="contact-item">
        <span class="label">DATE OF BIRTH</span>
        <span class="value">{birthDate} (Age {age})</span>
      </div>
    </div>

    <div class="sidebar-actions">
      <a href={cvPdf} download class="btn btn-primary full-width">Download CV</a>
      <a href={`mailto:${email}`} class="btn btn-outline full-width">Contact</a>
    </div>
  </div>
</aside>

<style>
  .sidebar-wrapper {
    position: relative;
    height: 100%;
  }
  .sticky-sidebar {
    position: sticky;
    top: 2rem;
  }
  .sidebar {
    padding: 2.5rem 2rem;
    display: flex;
    flex-direction: column;
    gap: 3rem;
    border-radius: 1.5rem;
  }
  .profile-section {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }
  .avatar-container {
    width: 160px;
    height: 160px;
    border-radius: 50%;
    padding: 4px;
    background: var(--accent-gradient);
    overflow: hidden;
  }
  .avatar {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    object-fit: cover;
    object-position: top;
    border: 4px solid var(--bg-color);
  }
  .name {
    font-size: 1.8rem;
    font-weight: 800;
    line-height: 1.2;
    margin-bottom: 0.5rem;
  }
  .title {
    font-size: 0.8rem;
    color: var(--text-secondary);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 1rem;
  }
  .vision {
    font-size: 0.85rem;
    line-height: 1.5;
    color: var(--accent-sky);
    font-weight: 600;
  }
  .contact-links {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  .contact-item {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }
  .contact-item .label {
    font-size: 0.65rem;
    font-weight: 700;
    color: var(--text-secondary);
    letter-spacing: 0.1em;
  }
  .contact-item .value {
    font-size: 0.9rem;
    font-weight: 600;
    word-break: break-word;
  }
  .sidebar-actions {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-top: auto;
  }
  .full-width {
    width: 100%;
  }

  @media (max-width: 1024px) {
    .sticky-sidebar { position: relative; top: 0; }
  }
</style>
